# PA Bot Environment Variables
# Copy this to .env and fill in your values.
# These override settings.yaml values when set.

# BitUnix API (optional -- only for authenticated endpoints)
BITUNIX_API_KEY=
BITUNIX_API_SECRET=

# Discord
DISCORD_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Coinalyze (free API -- OI, liquidations, long/short ratios)
# Get key at: https://en.coinalyze.net/account/api-key/
COINALYZE_API_KEY=

# PostgreSQL / TimescaleDB (Phase 7)
DATABASE_URL=postgresql://pabot:pabot@localhost:5432/pabot
POSTGRES_PASSWORD=pabot_secure_pw

# Grafana (Phase 7)
GRAFANA_PASSWORD=admin

# PA Bot Environment Variables
# Copy this to .env and fill in your values.
# These override settings.yaml values when set.

# BitUnix API (optional -- only for authenticated endpoints)
BITUNIX_API_KEY=
BITUNIX_API_SECRET=

# Discord
DISCORD_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
